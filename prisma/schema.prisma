// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ USER MODEL (required by auth routes) ============
model User {
  id        String    @id @default(cuid())
  fullName  String
  phone     String    @unique // 11 digits, e.g., 08012345678
  pinHash   String?   // Hashed 6-digit PIN using bcryptjs
  email     String?   @unique
  role      UserRole  @default(USER)
  tier      String    @default("user") // user, agent
  balance   Int       @default(0) // In naira
  isBanned  Boolean   @default(false)
  isActive  Boolean   @default(true)
  joinedAt  DateTime  @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relationships
  virtualAccount VirtualAccount?
  dataTransactions DataTransaction[]

  @@index([phone])
  @@index([role])
}

model VirtualAccount {
  id            String   @id @default(cuid())
  userId        String   @unique
  accountNumber String
  bankName      String
  accountName   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============ DATA SERVICES MODELS ============
model DataNetwork {
  id          String   @id @default(cuid())
  name        String   // e.g., "MTN", "GLO", "AIRTEL", "9MOBILE"
  networkCode Int      // 1-4
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  plans DataPlan[]

  @@unique([networkCode])
  @@index([name])
}

model DataPlan {
  id          String   @id @default(cuid())
  name        String   // e.g., "500MB 7 Days"
  networkId   String
  sizeLabel   String   // e.g., "500MB", "1GB"
  apiAId      Int?     // Provider A plan ID (SMEPlug)
  apiBId      Int?     // Provider B plan ID (Saiful)
  price       Decimal  // Price in naira, stored as Decimal
  activeApi   ActiveApi @default(A) // Which API to use: A or B
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  network DataNetwork @relation(fields: [networkId], references: [id], onDelete: Cascade)
  transactions DataTransaction[]

  @@index([networkId])
  @@index([isActive])
}

model DataTransaction {
  id                  String    @id @default(cuid())
  userId              String
  phone               String    // Recipient phone number
  planId              String
  networkId           String    // Denormalized for quick filtering
  amount              Int       // Amount in naira
  reference           String    @unique // Our unique reference (UUID/nanoid)
  providerReference   String?   // Provider's reference
  status              TransactionStatus @default(PENDING)
  apiUsed             ApiProvider? // Which provider actually processed (A or B)
  providerResponse    Json?     // Raw provider response stored for debugging
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan DataPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([phone])
}

// ============ ENUMS ============
enum UserRole {
  USER
  AGENT
  ADMIN
}

enum ActiveApi {
  A
  B
}

enum ApiProvider {
  A
  B
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}
