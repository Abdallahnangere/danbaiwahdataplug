// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ User Models ============

model User {
  id        String    @id @default(cuid())
  fullName  String
  phone     String    @unique // 11 digits, e.g., 08012345678
  pinHash   String?   // Hashed 6-digit PIN using bcryptjs
  email     String?   @unique
  role      UserRole  @default(USER) // USER, AGENT, ADMIN
  tier      String    @default("user") // user, agent
  balance   Int       @default(0) // In kobo (divide by 100 for naira)
  isBanned  Boolean   @default(false)
  isActive  Boolean   @default(true)
  joinedAt  DateTime  @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relationships
  virtualAccount VirtualAccount?
  transactions   Transaction[]
  userRewards    UserReward[]
  account        Account?

  @@index([phone])
  @@index([role])
}

model VirtualAccount {
  id            String   @id @default(cuid())
  userId        String   @unique
  accountNumber String
  bankName      String
  accountName   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Int      @default(0) // In kobo
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============ Plan Models ============

model Plan {
  id                String   @id @default(cuid())
  name              String   // e.g., "MTN 1GB 7 Days"
  network           Network  // MTN, GLO, AIRTEL, NINEMOBILE
  sizeLabel         String   // e.g., "1GB"
  validity          String   // e.g., "7 days"
  price             Int      // Price in naira (will be multiplied by 100 for kobo in code)
  agentPrice        Int      @default(0) // Agent discount price
  apiSource         ApiSource // API_A (SMEPlug) or API_B (Saiful)
  externalPlanId    Int      // Plan ID from external API
  externalNetworkId Int      // Network ID from external API
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  transactions Transaction[]

  @@unique([apiSource, externalPlanId, externalNetworkId])
  @@index([network])
  @@index([isActive])
}

model CablePlan {
  id        String   @id @default(cuid())
  provider  String   // DSTV, GOTV, STARTIME
  planId    Int      // Provider's plan ID
  name      String   // Plan name
  amount    Int      // Price in naira
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, planId])
  @@index([provider])
}

model Disco {
  id         String   @id @default(cuid())
  name       String   // Display name: "Ikeja Electric"
  slug       String   @unique // URL-friendly slug: "ikeja-electric"
  externalId Int      // Saiful's DISCO ID (1-11)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([externalId])
}

// ============ Transaction Models ============

model Transaction {
  id                String      @id @default(cuid())
  userId            String? // Null for guest purchases
  type              TransactionType
  method            String?     // WIAXY, API, MANUAL
  amount            Int         // In naira (for display/calculation)
  status            TransactionStatus @default(PENDING) // PENDING, SUCCESS, FAILED, COMPLETED
  reference         String      @unique // Transaction reference for idempotency
  externalReference String?     // External API reference
  description       String?     // What was purchased/credited
  phone             String?     // Recipient phone number
  guestPhone        String?     // For guest purchases
  planId            String?     // For data purchases
  apiUsed           ApiSource?  // Which API was used
  metadata          Json?       // Service-specific metadata
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  plan Plan?  @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([phone])
}

// ============ Reward Models ============

model Reward {
  id          String   @id @default(cuid())
  type        String   // FIRST_DEPOSIT_2K, DEPOSIT_10K_UPGRADE, etc.
  title       String   // Display title
  description String?  // Description
  amount      Int      // Reward amount in naira
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRewards UserReward[]

  @@index([type])
}

model UserReward {
  id        String   @id @default(cuid())
  userId    String
  rewardId  String
  status    RewardStatus @default(IN_PROGRESS) // IN_PROGRESS, EARNED, CLAIMED
  claimedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  reward Reward @relation(fields: [rewardId], references: [id], onDelete: Cascade)

  @@unique([userId, rewardId])
  @@index([userId])
  @@index([status])
}

// ============ Enums ============

enum UserRole {
  USER
  AGENT
  ADMIN
}

enum TransactionType {
  DATA_PURCHASE
  AIRTIME_PURCHASE
  CABLE_SUBSCRIPTION
  ELECTRICITY_PAYMENT
  EXAMPIN_PURCHASE
  DEPOSIT
  WALLET_FUNDING
  REWARD_CREDIT
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  COMPLETED
}

enum ApiSource {
  API_A // SMEPlug
  API_B // Saiful
}

enum Network {
  MTN
  GLO
  AIRTEL
  NINEMOBILE
}

enum RewardStatus {
  IN_PROGRESS
  EARNED
  CLAIMED
}
