// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// AUDIT NOTES:
// - No existing User model found — creating from scratch
// - No DataPlan model found (creating)
// - No DataTransaction model found (creating)
// - Adding pin field to User as nullable String (6-digit bcrypt hash)
// - Relations: User -> DataTransaction[], DataPlan -> DataTransaction[]

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// USER MODEL
// ─────────────────────────────────────────────────────────────
model User {
  id            String   @id @default(cuid())
  name          String
  phone         String   @unique
  email         String?  @unique
  pin           String?  // 6-digit bcrypt hash, nullable until user sets it
  balance       Decimal  @default(0) @db.Decimal(15, 2)  // Monetary amount in naira
  role          String   @default("USER") // "USER" | "AGENT" | "ADMIN"
  tier          String   @default("user") // "user" | "agent"
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  dataPurchases DataTransaction[]
}

// ─────────────────────────────────────────────────────────────
// DATA PLAN MODEL
// ─────────────────────────────────────────────────────────────
model DataPlan {
  id            String   @id @default(cuid())
  name          String                          // e.g. "1GB Daily"
  networkId     Int                             // 1=MTN 2=Glo 3=9mobile 4=Airtel
  networkName   String                          // Human label
  sizeLabel     String                          // e.g. "1GB"
  validity      String                          // e.g. "24hrs"
  price         Decimal  @db.Decimal(10, 2)     // What user pays (naira)
  userPrice     Decimal? @db.Decimal(10, 2)     // Price for regular users
  agentPrice    Decimal? @db.Decimal(10, 2)     // Price for agents (lower)
  apiAId        Int?                            // Plan ID on SMEPlug (API A)
  apiBId        Int?                            // Plan ID on API B
  activeApi     String   @default("A")          // "A" or "B" — which provider serves this plan
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transactions  DataTransaction[]
}

// ─────────────────────────────────────────────────────────────
// DATA TRANSACTION MODEL
// ─────────────────────────────────────────────────────────────
model DataTransaction {
  id               String   @id @default(cuid())
  userId           String
  planId           String
  phone            String
  networkId        Int
  amount           Decimal  @db.Decimal(10, 2)  // Monetary amount in naira
  providerUsed     String                       // "A" or "B"
  providerRef      String?                      // Reference returned by provider
  providerResponse String?                      // Raw api_response string
  status           String   @default("pending") // "pending" | "successful" | "failed"
  balanceBefore    Decimal? @db.Decimal(10, 2) // Balance before transaction
  balanceAfter     Decimal? @db.Decimal(10, 2) // Balance after transaction
  customerRef      String?                      // Our internal idempotency ref
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan DataPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
}
